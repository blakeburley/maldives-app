# =============================================================================
# .env.example — Copy to .env and fill in values for your environment
# The app works with zero configuration locally (all defaults are fine).
# =============================================================================

# Port the server listens on (default: 3000)
PORT=3000

# Path to the SQLite database file.
# Default: maldives.db in the same folder as server.js.
# On Railway/Render with a persistent volume, set this to the volume path:
#   DB_PATH=/data/maldives.db
DB_PATH=maldives.db
